generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Gym {
  id             String         @id @default(uuid())
  name           String
  slug           String         @unique
  timezone       String         @default("UTC")
  currency       String         @default("INR")
  opening_hours  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  bannerUrl      String?
  fontFamily     String?        @default("'Inter', sans-serif")
  logoUrl        String?
  primaryColor   String?        @default("#4F46E5")
  secondaryColor String?        @default("#8B5CF6")
  upiId          String?
  upiNumber      String?
  upiQrUrl       String?
  instagramLink  String?
  locationDesc   String?
  whatsappNumber String?
  announcements  Announcement[]
  attendances    Attendance[]
  auditLogs      AuditLog[]
  timings        GymTiming[]
  memberships    Membership[]
  offers         Offer[]
  payments       Payment[]
  services       Service[]
  trainers       Trainer[]
  users          User[]
  weightGoals    WeightGoal[]
  workouts       Workout[]
}

model Offer {
  id          String   @id @default(uuid())
  gymId       String
  title       String
  description String
  code        String?
  color       String   @default("#f59e0b")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model Service {
  id          String   @id @default(uuid())
  gymId       String
  name        String
  description String
  iconName    String   @default("Zap")
  priceLabel  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model GymTiming {
  id         String   @id @default(uuid())
  gymId      String
  dayRange   String
  timeRange  String
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  gym        Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model User {
  id             String       @id @default(uuid())
  gymId          String
  name           String
  email          String?
  gender         String?
  phone          String?
  passwordHash   String?
  role           Role         @default(MEMBER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  photoUrl       String?
  attendances    Attendance[]
  auditLogActor  AuditLog[]   @relation("AuditLogActor")
  auditLogTarget AuditLog[]   @relation("AuditLogTarget")
  memberships    Membership[]
  payments       Payment[]
  gym            Gym          @relation(fields: [gymId], references: [id], onDelete: Cascade)
  weightGoals    WeightGoal[]
  workouts       Workout[]

  @@unique([gymId, phone])
  @@unique([gymId, email], name: "gymId_email")
}

model Plan {
  id           String       @id @default(uuid())
  name         String       @unique
  durationDays Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  Membership[]
}

model Membership {
  id                 String           @id @default(uuid())
  userId             String
  planId             String
  gymId              String
  startDate          DateTime
  endDate            DateTime
  status             MembershipStatus @default(PENDING)
  freezeDate         DateTime?
  expectedResumeDate DateTime?
  autoRenew          Boolean          @default(true)
  lastNotifiedAt     DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  gym                Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  plan               Plan             @relation(fields: [planId], references: [id])
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments           Payment[]
}

model Attendance {
  id        String   @id @default(uuid())
  userId    String
  gymId     String
  date      DateTime @db.Date
  timestamp DateTime @default(now())
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id           String        @id @default(uuid())
  userId       String
  gymId        String
  membershipId String?
  amount       Decimal       @db.Decimal(10, 2)
  currency     String
  status       PaymentStatus @default(PENDING)
  externalId   String?
  date         DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  gym          Gym           @relation(fields: [gymId], references: [id], onDelete: Cascade)
  membership   Membership?   @relation(fields: [membershipId], references: [id])
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trainer {
  id             String   @id @default(uuid())
  gymId          String
  name           String
  specialization String
  photoUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  bio            String?
  gym            Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model Workout {
  id       String   @id @default(uuid())
  userId   String
  gymId    String
  title    String
  calories Int?
  duration Int?
  date     DateTime @default(now())
  gym      Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeightGoal {
  id             String   @id @default(uuid())
  userId         String
  gymId          String
  currentWeight  Float
  targetWeight   Float
  caloriesBurned Int      @default(0)
  updatedAt      DateTime @updatedAt
  gym            Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  gymId     String
  actorId   String?
  targetId  String?
  action    String
  oldData   Json?
  newData   Json?
  ipAddress String?
  timestamp DateTime @default(now())
  actor     User?    @relation("AuditLogActor", fields: [actorId], references: [id])
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  target    User?    @relation("AuditLogTarget", fields: [targetId], references: [id])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  FROZEN
  PENDING
}

enum PaymentStatus {
  SUCCESS
  PENDING
  FAILED
}

model Announcement {
  id        String   @id @default(uuid())
  gymId     String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
}
